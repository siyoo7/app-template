# ----------------------------------------------------------------------------
# .env.example — copy to .env.local and fill in. Never commit .env.local.
# The bootstrap script populates most of these automatically.
# ----------------------------------------------------------------------------

# ---- Convex ---------------------------------------------------------------
# Frontend connects to this URL. Written by `npx convex dev --once --configure=new`.
VITE_CONVEX_URL=
# Convex CLI deployment id (dev:<name> or prod:<name>).
CONVEX_DEPLOYMENT=

# ---- Clerk (frontend) -----------------------------------------------------
# Safe in browser bundles. pk_test_... in dev, pk_live_... in prod.
VITE_CLERK_PUBLISHABLE_KEY=

# ---- Clerk (server / Convex) ----------------------------------------------
# Set on Convex via `npx convex env set`. Listed here for `convex dev` local use.
CLERK_SECRET_KEY=
# JWT issuer URL — Convex uses this to validate auth tokens.
CLERK_ISSUER_URL=
# Webhook signing secret — different per environment.
CLERK_WEBHOOK_SECRET=

# ---- Stripe (Phase E only — leave blank until activating) -----------------
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# ---- Local dev convenience -----------------------------------------------
# "true" only in .env.local — bypasses Clerk for local UI testing.
VITE_BYPASS_AUTH=false
